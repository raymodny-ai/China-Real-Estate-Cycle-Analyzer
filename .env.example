# 环境变量示例文件
# 复制此文件为 .env 并填入实际值

# ─────────────────────────────────────────────────────────────────────────────
# 应用配置
# ─────────────────────────────────────────────────────────────────────────────

# 运行环境: dev / staging / production
ENV=dev

# Streamlit 配置
STREAMLIT_SERVER_PORT=8501
STREAMLIT_SERVER_HEADLESS=true

# 日志级别: DEBUG / INFO / WARNING / ERROR
LOG_LEVEL=INFO


# ─────────────────────────────────────────────────────────────────────────────
# 数据源 API 配置
# ─────────────────────────────────────────────────────────────────────────────

# 国家统计局 API (https://data.stats.gov.cn)
NBS_API_KEY=your_nbs_api_key_here

# 东方财富 Choice 金融终端
CHOICE_API_KEY=your_choice_api_key_here
CHOICE_BASE_URL=http://localhost:8765

# 克而瑞 CRIC
CRIC_API_KEY=your_cric_api_key_here
CRIC_BASE_URL=https://api.cric.com


# ─────────────────────────────────────────────────────────────────────────────
# 数据库配置
# ─────────────────────────────────────────────────────────────────────────────

# SQLite (默认，无需修改)
DB_PATH=data/housing_data.db


# ─────────────────────────────────────────────────────────────────────────────
# 部署配置 (生产环境)
# ─────────────────────────────────────────────────────────────────────────────

DEPLOY_HOST=your_server_ip
DEPLOY_USER=deploy
DEPLOY_KEY_PATH=~/.ssh/deploy_key
